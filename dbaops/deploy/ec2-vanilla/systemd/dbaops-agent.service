# DBAOps Agent — LangGraph 에이전트, 한 프로세스가 두 포트 서빙:
#   :8080 HTTP /invocations (UI·Slack)  +  :9102 A2A (perf 에이전트)
[Unit]
Description=DBAOps Agent
After=network-online.target dbaops-mcp-router.service
Wants=network-online.target
Requires=dbaops-mcp-router.service

[Service]
Type=simple
User=__USER__
WorkingDirectory=__REPO__/agent
EnvironmentFile=/etc/dbaops/dbaops.env
Environment=GATEWAY_ENDPOINT=http://127.0.0.1:9000/mcp
Environment=DBAOPS_DATA_DIR=__DATA__
Environment=PORT=8080
Environment=DBAOPS_A2A_HOST=0.0.0.0
Environment=DBAOPS_A2A_PORT=9102
Environment=DBAOPS_A2A_URL=http://127.0.0.1:9102/
Environment=PERF_A2A_URL=http://127.0.0.1:9100
ExecStart=__VENV__/bin/python -m dbaops_agent.runtime_entry
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
