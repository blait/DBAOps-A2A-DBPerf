# DBAOps-Agent 생 EC2 배포 — 환경변수. install.sh 가 /etc/dbaops/dbaops.env 로 복사한다.
# 수정 후:  sudo systemctl restart dbaops-mcp-router dbaops-agent dbaops-streamlit dbaops-slack-bot

# ─── AWS ───
# EC2 instance role 사용(IMDS 자동) — 자격증명 키 불필요, 리전만 맞추면 됨.
AWS_REGION=ap-northeast-2
BEDROCK_REGION=ap-northeast-2

# ─── Bedrock LLM ───
# instance role 에 이 모델의 bedrock:InvokeModel 권한 필수.
BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-7

# ─── Slack (Socket Mode, 선택) ───
# 토큰 채운 뒤: sudo systemctl enable --now dbaops-slack-bot
#SLACK_BOT_TOKEN=xoxb-...
#SLACK_APP_TOKEN=xapp-...
# Slack 차트 링크에 쓸 Streamlit 외부 URL (예: http://<EC2-IP>:8501)
#STREAMLIT_URL=

LOG_LEVEL=INFO
