# DBAOps-Agent 올인원 EC2 — 환경변수. 복사해서 .env 로 사용.
#   cp .env.example .env  &&  편집

# ─── AWS ───
# EC2 instance role 을 쓰면 자격증명 키는 불필요(IMDS 자동). 리전만 맞추면 됨.
AWS_REGION=ap-northeast-2

# 로컬/테스트에서 instance role 대신 ~/.aws 를 컨테이너에 마운트하려면 경로 지정.
# (EC2 instance role 사용 시에는 이 줄을 비워두거나 /dev/null 유지)
# AWS_SHARED_DIR=/home/ec2-user/.aws

# ─── Bedrock LLM ───
# 이 모델 호출 권한(bedrock:InvokeModel)이 instance role 에 반드시 있어야 함.
BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-7

# ─── Streamlit ───
STREAMLIT_PORT=8501
# 외부에서 접속할 Streamlit URL (Slack 리포트의 차트 링크에 사용). 예: http://<ec2-public-ip>:8501
STREAMLIT_URL=

# ─── Slack (Socket Mode) ───
# 봇을 안 쓸 거면 비워둬도 되지만, slack-bot 컨테이너가 토큰 없이 죽으며 재시작 루프를 돌 수 있음.
# 그 경우 docker compose up 시 streamlit/agent/mcp-router 만 올리거나 slack-bot 을 스케일 0.
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ─── Prometheus 스택 (선택, --profile prometheus 일 때만) ───
# 고객 Prometheus 데모용. RDS 메트릭을 exporter 로 뽑아 Prometheus 가 수집.
# 외부 노출 포트(데모 확인용, SG 로 내 IP 한정 권장).
PROMETHEUS_PORT=9090
# postgres-exporter 접속 DSN. PG 비번엔 특수문자가 없어 그대로 인라인 가능.
#   postgresql://<user>:<pw>@<host>:5432/<db>?sslmode=require
PG_EXPORTER_DSN=postgresql://dbaops:CHANGE_ME@dbaops-seoul-test-pg.cb9lthnbapty.ap-northeast-2.rds.amazonaws.com:5432/appdb?sslmode=require
# mysqld-exporter 는 비번 특수문자 때문에 prometheus/my.cnf 파일로 설정(my.cnf.example 참고).

LOG_LEVEL=INFO
