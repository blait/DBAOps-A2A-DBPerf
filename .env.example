# ── 공통 ─────────────────────────────────────────────
AWS_REGION=ap-northeast-2
LOG_LEVEL=INFO
# 로컬 테스트 시 ~/.aws 마운트 (EC2 instance role이면 그대로 둠)
#AWS_SHARED_DIR=~/.aws

# ── DBAOps (ec2-allinone) ────────────────────────────
BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-7
STREAMLIT_PORT=8501
# 리포트 차트 링크(선택)
#STREAMLIT_URL=http://<ec2-ip>:8501

# ── Slack (Socket Mode 봇 + perf 알림 공용) ──────────
# deploy/ec2-allinone/SLACK_SETUP.md (dbaops/ 안) 참고 — 토큰 2개 발급
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
# perf 에이전트 알림 기본 채널 (#이름 또는 채널 ID)
SLACK_CHANNEL=#dbops-alerts

# ── SQL Server Perf Agent ────────────────────────────
PERF_BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
DB_SECRET_ID=dbops-sqlserver-secret
DB_NAME=master
PERF_STREAMLIT_PORT=8502
